# PostgreSQL Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_NAME=shar_messenger
DB_USER=postgres
DB_PASSWORD=postgres

# Use PostgreSQL instead of JSON
USE_POSTGRES=true

# Optional: Keep JSON database for backup
KEEP_JSON_BACKUP=true

# Persistent storage for attachments/avatars (set outside release directory)
# Linux example: /var/lib/shar/uploads
# Windows example: D:/shar/uploads
SHAR_UPLOADS_DIR=

# S3/Object Storage (Yandex Object Storage)
# When enabled, /api/upload and /api/avatars use S3 instead of local disk
S3_ENABLED=false
S3_ENDPOINT=https://storage.yandexcloud.net
S3_REGION=ru-central1
S3_BUCKET=
S3_ACCESS_KEY=
S3_SECRET_KEY=
# Files larger than threshold go to S3, smaller files stay on local disk
S3_UPLOAD_THRESHOLD_BYTES=122880

# Other existing environment variables...
# TELEGRAM_BOT_TOKEN=...
# YANDEX_METRICA_TOKEN=...
# etc.
