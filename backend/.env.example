# PostgreSQL Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_NAME=shar_messenger
DB_USER=postgres
DB_PASSWORD=postgres

# Use PostgreSQL instead of JSON
USE_POSTGRES=true

# Optional: Keep JSON database for backup
KEEP_JSON_BACKUP=true

# Persistent storage for attachments/avatars (set outside release directory)
# Linux example: /var/lib/shar/uploads
# Windows example: D:/shar/uploads
SHAR_UPLOADS_DIR=

# Other existing environment variables...
# TELEGRAM_BOT_TOKEN=...
# YANDEX_METRICA_TOKEN=...
# etc.
